{
  "name": "@inkress/apps-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared SDK for Inkress-embedded apps: server session/OAuth handshake, Inkress API client, browser UI kit + design system.",
  "type": "module",
  "main": "./src/server.mjs",
  "exports": {
    ".": "./src/server.mjs",
    "./server": "./src/server.mjs",
    "./inkress-api": "./src/inkress-api.mjs",
    "./session-store": "./src/session-store.mjs",
    "./db": "./src/db.mjs",
    "./pgdb": "./src/pgdb.mjs",
    "./ses": "./src/ses.mjs",
    "./sns": "./src/sns.mjs",
    "./storage": "./src/storage.mjs",
    "./pdf": "./src/pdf.mjs",
    "./merchant-tokens": "./src/merchant-tokens.mjs",
    "./channel": "./src/channel.mjs",
    "./bookerva": "./src/bookerva-client.mjs",
    "./browser": "./src/browser.ts",
    "./ui": "./src/ui.ts",
    "./icons": "./src/icons.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1041.0",
    "@aws-sdk/client-sns": "^3.1041.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@inkress/app-bridge": "github:jamlance/app-bridge",
    "pdf-lib": "^1.17.1",
    "better-sqlite3": "^11.5.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
